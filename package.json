{
  "name": "autolooper",
  "version": "0.4.2",
  "private": true,
  "description": "Desktop batch loop marker editor for game music files.",
  "main": "dist-electron/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && electron .",
    "build": "tsc -p tsconfig.electron.json && tsc -p tsconfig.json && vite build",
    "dist:dir": "npm run build && electron-builder --win dir --x64",
    "dist": "npm run build && electron-builder --win portable --x64",
    "dist:mac:dir": "npm run build && electron-builder --mac dir --universal --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "test": "vitest run",
    "preview": "vite preview --host 127.0.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.556.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.autolooper.app",
    "productName": "AutoLooper",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}.${version}.${ext}",
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "build/icon.ico",
      "build/icon.png",
      "README.md",
      "package.json"
    ],
    "asar": true,
    "icon": "build/icon.ico",
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "category": "public.app-category.music",
      "artifactName": "${productName}.${version}.mac.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    }
  }
}
